{
  "expo": {
    "name": "ToyHUB",
    "slug": "toyhub",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1F7A4F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.toyhub.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Чтобы показать залы в вашем городе"
      }
    },
    "android": {
      "package": "com.toyhub.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1F7A4F"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-localization",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Чтобы показать залы в вашем городе"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1F7A4F"
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "http://10.0.2.2:4000",
      "eas": {
        "projectId": "7c79644f-3506-411e-816c-23a58d39cf1c"
      }
    },
    "owner": "damirrisbekov",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7c79644f-3506-411e-816c-23a58d39cf1c"
    }
  }
}
